# Node.js specific files and directories
# -------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/
.npm/

# Build and Distribution folders
# -----------------------------
dist/
build/
out/
.next/             # Next.js build output
.svelte-kit/       # SvelteKit build output
public/build/      # Common if frontend builds to a public subfolder
# Vite specific (if using Vite):
.vite/
# Webpack/Rollup specific (if using these bundlers directly):
webpack-build/
esbuild-build/

# Environment variables (CRITICAL: NEVER commit these!)
# ----------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env.*

# Logs, Temporary Files, and Cache
# --------------------------------
*.log
*.tmp
*.bak
*.swp                # Vim swap files
*.swo                # Vim swap files
.eslintcache         # ESLint cache
.parcel-cache/       # Parcel bundler cache
*.sqlite
*.sqlite3
*.db
*.mv.db              # H2 database file
npm-cache/
yarn-cache/

# Operating System Specific Files
# -------------------------------
.DS_Store            # macOS
Thumbs.db            # Windows
desktop.ini          # Windows

# IDE/Editor Specific Files (configure based on your team's preference)
# ---------------------------------------------------------------------
.idea/               # JetBrains IDEs (IntelliJ, WebStorm, etc.)
.vscode/             # VS Code workspace settings (uncomment if you want to ignore *all* .vscode settings)
# If you only want to ignore specific local VS Code settings, keep .vscode/ and add:
# .vscode/*.local.json
# .vscode/settings.json # if you don't want to share global project settings
# .vscode/tasks.json    # if your tasks are specific to your machine
# .vscode/launch.json   # if your debug configs are personal
*.iml                # IntelliJ IDEA module files
*.project
*.sublime-workspace
*.code-workspace

# Test and Coverage reports
# -------------------------
coverage/
.nyc_output/         # nyc (Istanbul) coverage output

# Solana / Anchor / Rust Specific Development Artifacts
# -----------------------------------------------------
# Local keypair files (CRITICAL: NEVER commit production/mainnet keys!)
# These are often generated for local testing/development.
# Be cautious if your project naturally generates JSON files that *should* be tracked.
*.json               # Only if ALL JSON files generated in your root are temporary/keypairs.
id.json              # Common filename for local test keypairs (e.g., from `solana-keygen new`)
temp-key.json
anchor-keypair.json

.anchor/             # Anchor framework build/cache artifacts
target/              # Rust/Cargo/Anchor compilation output

# For local Solana validator ledger (if you're running `solana-test-validator`)
# This directory can grow very large and is not part of source code.
ledger/
test-ledger/
.test-ledger/

# Rust-related temporary files/backups
Cargo.lock           # Typically committed for applications for reproducible builds.
                     # Uncomment to ignore if it's a library or you manage dependencies differently.
**/*.rs.bk           # Backup files generated by rustfmt or editors

# Database specific files (if you have local development databases)
# -----------------------------------------------------------------
# For SQLite, already included above, but here for clarity:
# *.sqlite
# *.sqlite3
# For PostgreSQL/MySQL client configs/data if stored locally:
# pgdata/
# mysql_data/

# Docker specific (if using Docker for local dev)
# -----------------------------------------------
.dockerignore        # This file itself should be committed
# Uncomment if you want to ignore images/volumes that Docker might create locally
# docker-compose.yml.orig

# General ignores
# ---------------
*.log
*.pid
*.seed
*.pid
.DS_Store
.history/             # VS Code Local History